<Window x:Class="lr9.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="294" Width="350" Background="White"
        ScrollViewer.VerticalScrollBarVisibility="Disabled"
        MaxWidth="400"
        MaxHeight="400"
        MinWidth="400"
        MinHeight="400">

    <Grid Margin="20,20,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="IP:"/>
            <TextBox x:Name="IpBox" Text="192.168.0.107"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Порт:"/>
            <TextBox x:Name="PortBox" Text="5432"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="База данных:"/>
            <TextBox x:Name="databaseBox" Text=""/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Логин:"/>
            <TextBox x:Name="UsernameBox" Text="postgres"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PasswordBox" Password=""/>
        </StackPanel>

        <Button Content="Войти"
                Grid.Row="5"
                Height="39"
                Click="Login_Click"
                x:Name="LoginButton"/>

        <CheckBox Content="Безопасный режим"
                  Grid.Row="6"
                  x:Name="SafeModeCheckBox"
                  IsChecked="True"
                  IsEnabled="False"/>
    </Grid>
</Window>